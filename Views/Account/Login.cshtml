@* Widok logowania. Logikę i walidację (tagi asp-) zrobił kolega z backendu —
   NIE ruszamy tagów asp-. Tu dokładamy tylko warstwę wizualną (style SmaczaPL). *@
@model Techniki_Internetowe_Proj.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Logowanie";
}

<section class="auth-page">
    <div class="auth-card">
        <h1>Zaloguj się</h1>
        <p class="auth-sub">Witaj ponownie w SmaczaPL 🍳</p>

        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="All" class="auth-validation"></div>

            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="auth-input" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="auth-input" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-check-row">
                <input asp-for="RememberMe" />
                <label asp-for="RememberMe"></label>
            </div>

            <button type="submit" class="hero-btn hero-btn-primary auth-submit">Zaloguj się</button>
        </form>

        <p class="auth-switch">Nie masz konta? <a asp-controller="Account" asp-action="Register">Zarejestruj się</a></p>
    </div>
</section>

@section Scripts {
    @* jQuery + skrypty walidacji TYLKO na tej stronie (globalny layout zostaje bez jQuery) *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
