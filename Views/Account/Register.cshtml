@* Widok rejestracji. Logikę i walidację (tagi asp-) zrobił kolega z backendu —
   NIE ruszamy tagów asp-. Tu dokładamy tylko warstwę wizualną (style SmaczaPL). *@
@model Techniki_Internetowe_Proj.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Rejestracja";
}

<section class="auth-page">
    <div class="auth-card">
        <h1>Załóż konto</h1>
        <p class="auth-sub">Dołącz do SmaczaPL i zapisuj swoje przepisy 🍽️</p>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="All" class="auth-validation"></div>

            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="auth-input" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="auth-input" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="auth-input" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="hero-btn hero-btn-primary auth-submit">Zarejestruj konto</button>
        </form>

        <p class="auth-switch">Masz już konto? <a asp-controller="Account" asp-action="Login">Zaloguj się</a></p>
    </div>
</section>

@section Scripts {
    @* jQuery + skrypty walidacji TYLKO na tej stronie (globalny layout zostaje bez jQuery) *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
