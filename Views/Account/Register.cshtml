@model Techniki_Internetowe_Proj.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Rejestracja";
}

<h2>Formularz Rejestracji (Szkielet Backendowy)</h2>

<form asp-action="Register" method="post">
    <div asp-validation-summary="All" style="color:red; font-weight:bold;"></div>

    <div style="margin-bottom: 15px;">
        <label asp-for="Email"></label><br />
        <input asp-for="Email" style="width: 300px; padding: 5px;" />
        <span asp-validation-for="Email" style="color:red;"></span>
    </div>

    <div style="margin-bottom: 15px;">
        <label asp-for="Password"></label><br />
        <input asp-for="Password" style="width: 300px; padding: 5px;" />
        <span asp-validation-for="Password" style="color:red;"></span>
    </div>

    <div style="margin-bottom: 15px;">
        <label asp-for="ConfirmPassword"></label><br />
        <input asp-for="ConfirmPassword" style="width: 300px; padding: 5px;" />
        <span asp-validation-for="ConfirmPassword" style="color:red;"></span>
    </div>

    <button type="submit" style="padding: 10px 20px; background-color: #007bff; color: white; border: none; cursor: pointer;">
        Zarejestruj konto
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}