@* Strona "Co mam w lodówce". Model to lista przepisów (do przeszukania przez JavaScript).
   Składniki WPISUJE się w polu tekstowym (z podpowiedziami) i dodaje jako "chipy". *@
@model List<Recipe>
@{
    ViewData["Title"] = "Co mam w lodówce?";
}

<section class="fridge-page">
    <h1>Co mam w lodówce? 🧊</h1>
    <p>Wpisz składniki, które masz w domu, a pokażemy, co możesz z nich ugotować.</p>

    <form id="fridgeForm" class="fridge-form">
        <div class="fridge-input-row">
            <input type="text" id="fridgeInput" list="ingredientsDatalist"
                   placeholder="wpisz składnik, np. jajka..." autocomplete="off" aria-label="Składnik" />
            <button type="button" id="addFridgeIngredient" class="hero-btn hero-btn-outline">+ Dodaj</button>
        </div>

        @* Tutaj JavaScript dodaje wpisane składniki jako "chipy" *@
        <ul class="fridge-chips" id="fridgeChips" aria-label="Twoje składniki"></ul>

        <div class="fridge-actions">
            <button type="submit" class="hero-btn hero-btn-primary">Szukaj przepisów</button>
            <button type="button" id="clearFridge" class="hero-btn hero-btn-outline">Wyczyść</button>
        </div>
    </form>

    @* Lista podpowiedzi składników (wypełnia ją JavaScript z pliku JSON) *@
    <datalist id="ingredientsDatalist"></datalist>

    <section class="fridge-results" aria-label="Pasujące przepisy">
        <p id="fridgeHint">Dodaj składniki i kliknij „Szukaj przepisów".</p>

        <div class="recipe-grid" id="fridgeGrid">
            @foreach (var recipe in Model)
            {
                @* data-ingredients zawiera nazwy składników rozdzielone znakiem "|" — czyta je JavaScript *@
                <article class="recipe-card fridge-card" hidden
                         data-title="@recipe.Title"
                         data-ingredients="@string.Join("|", recipe.Ingredients.Select(i => i.Name))">
                    <a asp-controller="Home" asp-action="Details" asp-route-id="@recipe.Id">
                        <img src="@recipe.ImageUrl" alt="Zdjęcie dania: @recipe.Title" />
                        <div class="recipe-card-body">
                            <span class="badge-kat">@recipe.Category?.Name</span>
                            <h2>@recipe.Title</h2>
                            <p class="time">⏱ @recipe.PrepTimeMinutes min</p>
                            @* Notkę o dopasowaniu (czego brakuje / można zrobić) wpisuje JavaScript *@
                            <p class="match-note"></p>
                        </div>
                    </a>
                </article>
            }
        </div>
    </section>
</section>

@section Scripts {
    <script src="~/js/ingredients-datalist.js" asp-append-version="true"></script>
    <script src="~/js/fridge.js" asp-append-version="true"></script>
}
